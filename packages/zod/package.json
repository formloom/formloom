{
  "name": "@formloom/zod",
  "version": "0.2.0",
  "description": "Zod and Standard Schema adapters for Formloom — validate submitted FormloomData with Zod or any Standard Schema consumer.",
  "license": "MIT",
  "author": "Formloom contributors",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist .turbo"
  },
  "keywords": [
    "form",
    "llm",
    "zod",
    "standard-schema",
    "validation",
    "formloom"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/formloom/formloom.git",
    "directory": "packages/zod"
  },
  "homepage": "https://github.com/formloom/formloom/tree/main/packages/zod#readme",
  "bugs": {
    "url": "https://github.com/formloom/formloom/issues"
  },
  "dependencies": {
    "@formloom/schema": "workspace:*"
  },
  "peerDependencies": {
    "zod": "^3.23.0 || ^4.0.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "zod": "^3.25.76"
  }
}
