{
  "name": "@formloom/react",
  "version": "0.3.0",
  "description": "Headless React hooks for rendering Formloom schemas — visibility, sections, async validators, file handling",
  "license": "MIT",
  "author": "Formloom contributors",
  "keywords": [
    "form",
    "react",
    "hook",
    "llm",
    "ai",
    "headless",
    "formloom"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist .turbo"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/formloom/formloom.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/formloom/formloom/tree/main/packages/react#readme",
  "bugs": {
    "url": "https://github.com/formloom/formloom/issues"
  },
  "dependencies": {
    "@formloom/schema": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "@types/react": "^19.0.0",
    "@testing-library/react": "^16.0.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0"
  }
}
